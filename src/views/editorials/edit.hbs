<h2>Editar Editorial</h2>

<form method="POST">
    <input type="text" name="name" value="{{editorial.name}}" class="form-control mb-2">
    <input type="text" name="phone" value="{{editorial.phone}}" class="form-control mb-2">
    <input type="text" name="country" value="{{editorial.country}}" class="form-control mb-2">

    <button class="btn btn-success">Actualizar</button>
    <a href="/editorials" class="btn btn-secondary">Volver</a>
</form>