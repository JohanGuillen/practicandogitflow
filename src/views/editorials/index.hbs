<h2>Editoriales</h2>

<a href="/editorials/create" class="btn btn-primary mb-3">Crear Editorial</a>

<table class="table table-dark">
    <thead>
        <tr>
            <th>Nombre</th>
            <th>Teléfono</th>
            <th>País</th>
            <th>Acciones</th>
        </tr>
    </thead>

    <tbody>
        {{#each editorials}}
        <tr>
            <td>{{this.name}}</td>
            <td>{{this.phone}}</td>
            <td>{{this.country}}</td>
            <td>
                <a href="/editorials/{{this.id}}/edit" class="btn btn-warning btn-sm">Editar</a>
                <a href="/editorials/{{this.id}}/delete" class="btn btn-danger btn-sm">Eliminar</a>
            </td>
        </tr>
        {{/each}}
    </tbody>
</table>