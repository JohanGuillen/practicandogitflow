<div class="container">

    <!-- TÍTULO -->
    <h1 class="mb-4 fw-bold">Home</h1>

    <!-- FILTROS -->
    <div class="row g-4 mb-4">

        <!-- BUSCAR -->
        <div class="col-md-4">
            <div class="card shadow-sm p-3 h-100 border-0">
                <h5 class="fw-bold mb-3">Buscar por nombre</h5>

                <form method="GET">
                    <label class="form-label">Nombre del libro</label>
                    <input 
                        type="text" 
                        name="search" 
                        class="form-control mb-3"
                        placeholder="Ej: Harry Potter"
                        value="{{search}}"
                    >

                    <button class="btn btn-primary w-100">
                        Buscar
                    </button>
                </form>
            </div>
        </div>

        <!-- FILTRAR POR CATEGORÍA -->
        <div class="col-md-4">
            <div class="card shadow-sm p-3 h-100 border-0">
                <h5 class="fw-bold mb-3">Filtrar por categoría</h5>

                <form method="GET">
                    <label class="form-label">Categoría</label>
                    <select name="category" class="form-select mb-3">
                        <option value="">Seleccione una categoría</option>

                        {{#each categories}}
                        <option value="{{this.id}}">
                            {{this.name}}
                        </option>
                        {{/each}}

                    </select>

                    <button class="btn btn-primary w-100">
                        Filtrar
                    </button>
                </form>
            </div>
        </div>

        <!-- FILTRAR POR AUTOR -->
        <div class="col-md-4">
            <div class="card shadow-sm p-3 h-100 border-0">
                <h5 class="fw-bold mb-3">Filtrar por autor</h5>

                <form method="GET">
                    <label class="form-label">Autor</label>
                    <select name="author" class="form-select mb-3">
                        <option value="">Seleccione un autor</option>

                        {{#each authors}}
                        <option value="{{this.id}}">
                            {{this.name}}
                        </option>
                        {{/each}}

                    </select>

                    <button class="btn btn-primary w-100">
                        Filtrar
                    </button>
                </form>
            </div>
        </div>

    </div>

    <!-- LISTADO -->
    <h2 class="mb-3 fw-bold">Listado de libros</h2>

    {{#if books.length}}

    <div class="row g-4">

        {{#each books}}
<div class="col-md-3">

    <a href="/books/{{this.id}}" style="text-decoration:none; color:black;">

        <div class="card shadow-sm h-100 border-0">

            <!-- IMAGEN -->
            <img 
                src="/uploads/{{this.cover}}" 
                class="card-img-top"
                style="height:250px; object-fit:cover;"
                onerror="this.src='https://via.placeholder.com/250'"
            >

            <!-- INFO -->
            <div class="card-body">
                <h5 class="fw-bold">{{this.title}}</h5>
                <p class="text-muted mb-1">
                    {{this.Author.name}}
                </p>

                <span class="badge bg-dark">
                    {{this.Category.name}}
                </span>
            </div>

        </div>

    </a>

</div>
        {{/each}}

    </div>

    {{else}}

    
    <div class="text-center mt-5">
        <h4 class="fw-bold">No hay libros registrados 📚</h4>
        <p class="text-muted">Empieza creando uno</p>

        <a href="/books/create" class="btn btn-dark">
            ➕ Crear Libro
        </a>
    </div>

    {{/if}}

</div>