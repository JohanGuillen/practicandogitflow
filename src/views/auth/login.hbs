<div class="d-flex justify-content-center align-items-center" style="height: 80vh;">

    <div class="card shadow-lg p-4" style="width: 400px; border-radius: 15px;">

        <div class="text-center mb-4">
            <h3 class="fw-bold">📚 BookApp</h3>
            <p class="text-muted">Inicia sesión</p>
        </div>

        {{#if error}}
        <div class="alert alert-danger text-center">
            <i class="bi bi-exclamation-triangle"></i> {{error}}
        </div>
        {{/if}}

        <form method="POST" action="/login">

            <div class="mb-3">
                <label class="form-label">Correo</label>
                <div class="input-group">
                    <span class="input-group-text">
                        <i class="bi bi-envelope"></i>
                    </span>
                    <input id="email" type="email" name="email" class="form-control" placeholder="admin@test.com" required>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label">Contraseña</label>
                <div class="input-group">
                    <span class="input-group-text">
                        <i class="bi bi-lock"></i>
                    </span>
                    <input id="password" type="password" name="password" class="form-control" placeholder="******" required>
                </div>
            </div>

      <button id="loginBtn" type="submit" class="btn btn-dark w-100">
    <i class="bi bi-box-arrow-in-right"></i> Entrar
</button>

        </form>

    </div>

</div>