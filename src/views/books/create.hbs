<h2 class="mb-4"> Crear Libro</h2>

{{#if error}}
<div class="alert alert-danger">
    {{error}}
</div>
{{/if}}

<form method="POST" enctype="multipart/form-data">

    <!-- TÍTULO -->
    <div class="mb-3">
        <label class="form-label">Título</label>
        <input 
            id="title"
            type="text" 
            name="title" 
            placeholder="Ej: Don Quijote" 
            class="form-control"
            value="{{data.title}}"
            required
        >
    </div>

    <!-- AÑO -->
    <div class="mb-3">
        <label class="form-label">Año</label>
        <input 
            id="year"
            type="number" 
            name="year" 
            placeholder="Ej: 2024" 
            class="form-control"
            value="{{data.year}}"
            required
        >
    </div>

    <!-- IMAGEN -->
    <div class="mb-3">
        <label class="form-label">Portada</label>
        <input 
            id="cover"
            type="file" 
            name="cover" 
            class="form-control"
        >
    </div>

    <!-- AUTOR -->
    <div class="mb-3">
        <label class="form-label">Autor</label>
        <select id="author" name="AuthorId" class="form-select" required>
            <option value="">Seleccione un autor</option>
            {{#each authors}}
            <option value="{{this.id}}" {{#ifEquals this.id ../data.AuthorId}}selected{{/ifEquals}}>
                {{this.name}}
            </option>
            {{/each}}
        </select>
    </div>

    <!-- CATEGORIA -->
    <div class="mb-3">
        <label class="form-label">Categoría</label>
        <select id="category" name="CategoryId" class="form-select" required>
            <option value="">Seleccione una categoría</option>
            {{#each categories}}
            <option value="{{this.id}}" {{#ifEquals this.id ../data.CategoryId}}selected{{/ifEquals}}>
                {{this.name}}
            </option>
            {{/each}}
        </select>
    </div>

    <!-- EDITORIAL -->
    <div class="mb-3">
        <label class="form-label">Editorial</label>
        <select id="editorial" name="EditorialId" class="form-select" required>
            <option value="">Seleccione una editorial</option>
            {{#each editorials}}
            <option value="{{this.id}}" {{#ifEquals this.id ../data.EditorialId}}selected{{/ifEquals}}>
                {{this.name}}
            </option>
            {{/each}}
        </select>
    </div>

    <!-- BOTONES -->
    <div class="d-flex gap-2">
        <button id="saveBtn" type="submit" class="btn btn-success">
            <i class="bi bi-save"></i> Guardar
        </button>

        <a href="/books" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Volver
        </a>
    </div>

</form>