<h2>Editar Libro</h2>

<form method="POST">

    <input type="text" name="title" value="{{book.title}}" class="form-control mb-2">
    <input type="number" name="year" value="{{book.year}}" class="form-control mb-2">

    <select name="AuthorId" class="form-control mb-2">
        {{#each authors}}
        <option value="{{this.id}}" {{#ifEquals this.id ../book.AuthorId}}selected{{/ifEquals}}>
            {{this.name}}
        </option>
        {{/each}}
    </select>

    <select name="CategoryId" class="form-control mb-2">
        {{#each categories}}
        <option value="{{this.id}}" {{#ifEquals this.id ../book.CategoryId}}selected{{/ifEquals}}>
            {{this.name}}
        </option>
        {{/each}}
    </select>

    <select name="EditorialId" class="form-control mb-2">
        {{#each editorials}}
        <option value="{{this.id}}" {{#ifEquals this.id ../book.EditorialId}}selected{{/ifEquals}}>
            {{this.name}}
        </option>
        {{/each}}
    </select>

    <button class="btn btn-success">Actualizar</button>
    <a href="/books" class="btn btn-secondary">Volver</a>

</form>