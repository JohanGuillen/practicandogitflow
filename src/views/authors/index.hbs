<h2>Autores</h2>

<a href="/authors/create" class="btn btn-primary mb-3">Crear Autor</a>

<table class="table table-dark">
    <thead>
        <tr>
            <th>Nombre</th>
            <th>Email</th>
            <th>Acciones</th>
        </tr>
    </thead>

    <tbody>
        {{#each authors}}
        <tr>
            <td>{{this.name}}</td>
            <td>{{this.email}}</td>
            <td>
                <a href="/authors/{{this.id}}/edit" class="btn btn-warning btn-sm">Editar</a>
                <a href="/authors/{{this.id}}/delete" class="btn btn-danger btn-sm">Eliminar</a>
            </td>
        </tr>
        {{/each}}
    </tbody>
</table>